# ============================================================
# pm_research .gitignore
# Repo should contain docs + code + tests + specs, not data.
# Raw/local data and generated artifacts stay local.
# ============================================================

# ----------------------------
# Secrets / credentials
# ----------------------------
.env
.env.*
*.key
*.pem
*.p12
*.crt
*.secret
secrets/
credentials/
*dune*api*
*api_key*
*API_KEY*
*token*
*TOKENS*

# ----------------------------
# Python caches / build outputs
# ----------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
build/
dist/
*.egg-info/
pip-wheel-metadata/

# ----------------------------
# Virtual environments
# ----------------------------
.venv/
venv/
env/
ENV/
conda-meta/

# ----------------------------
# Local raw data / large data formats
# ----------------------------
data/
data*/
*.parquet
*.pkl
*.pickle
*.feather
*.h5
*.hdf5
*.sqlite
*.sqlite3
*.db
*.duckdb

# ----------------------------
# Generated artifacts
# Keep artifact inventory/docs in project_context, not full outputs.
# Use artifacts_reference/ only for deliberately selected small snapshots.
# ----------------------------
artifacts/
!artifacts_reference/
!artifacts_reference/**

# ----------------------------
# Logs and local run outputs
# ----------------------------
logs/
*.log
*.out
*.err

# Root-level generated CSV / TXT run outputs
/candidates.csv
/classifier_sweep_results.csv
/wallets.txt
/repo_inventory_for_gitignore.csv
/repo_inventory_for_gitignore.txt
/data_inventory_do_not_commit.csv

# ----------------------------
# Local scratch / temporary work
# ----------------------------
_discovery_tmp/
tmp/
temp/
scratch/
*.tmp
*.bak
*.orig
*.swp

# ----------------------------
# Archives / copied bundles
# ----------------------------
*.zip
*.tar
*.tar.gz
*.7z
pm_research_full.zip

# ----------------------------
# Local helper scripts generated by assistants
# Commit manually only if intentionally part of the repo.
# ----------------------------
/apply_patch.sh

# ----------------------------
# OS / editor files
# ----------------------------
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

repo_audit_for_orchestrator/
