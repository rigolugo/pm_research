    "value": {
      "algorithm": "sha256(LF-joined canonical typed entry rows, no trailing LF)",
      "cardinality": 496,
      "entry_fields": [
        "execution_ordinal",
        "request_id"
      ],
      "entry_types": {
        "execution_ordinal": "UINT16",
        "request_id": "STRING matching ^req_[0-9a-f]{64}$"
      },
      "ordering": "execution_ordinal ascending exactly 0..495",
      "separator": "one byte LF between adjacent entries",
      "trailing_lf": false,
      "schema_id": "local_curl_initial_496_request_set_entry.v23"
    }
  },
